{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "Statement1",
			"Effect": "Allow",
			"Action": [
				"logs:CreateLogGroup",
				"logs:CreateLogStream",
				"logs:PutLogEvents"
			],
			"Resource": "arn:aws:logs:*:*:*"
		},
		{
			"Sid": "Statement2",
			"Effect": "Allow",
			"Action": [
				"ec2:CreateSnapshot",
				"ec2:DeleteSnapshot",
				"ec2:DescribeSnapshots",
				"ec2:CreateTags"
			],
			"Resource": "*"
		}
	]
}